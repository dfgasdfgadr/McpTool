{
  "manifest_version": 3,
  "name": "AI请求智能分析助手",
  "version": "1.0.0",
  "description": "基于AI智能分析请求用途与字段含义，支持修改响应数据",
  "permissions": ["storage", "scripting", "contextMenus", "tabs", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI请求智能分析助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "content/state.js",
        "content/mock-rules.js",
        "content/core.js",
        "content/ai-analysis.js",
        "content/mcp-engine.js",
        "content/flow-membership.js",
        "content/ui-core.js",
        "content/mcp-flow-dnd.js",
        "content/mcp-ui.js",
        "content/isolated.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
